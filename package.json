{
	"name": "todo.txt",
	"version": "1.0.1",
	"description": "A todo.txt-compatible plain text todo app built with React and Mantine",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"check": "biome check --write . && tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/groq": "^3.0.39",
		"@excalidraw/excalidraw": "0.18.1",
		"@mantine/core": "^9.2.2",
		"@mantine/form": "^9.2.2",
		"@mantine/hooks": "^9.2.2",
		"@mantine/tiptap": "^9.2.2",
		"@tiptap/core": "^3.24.0",
		"@tiptap/extension-placeholder": "^3.24.0",
		"@tiptap/extension-task-item": "^3.24.0",
		"@tiptap/extension-task-list": "^3.24.0",
		"@tiptap/markdown": "^3.24.0",
		"@tiptap/pm": "^3.24.0",
		"@tiptap/react": "^3.24.0",
		"@tiptap/starter-kit": "^3.24.0",
		"ai": "^6.0.194",
		"file-saver": "^2.0.5",
		"firebase": "^12.14.0",
		"lucide-react": "^1.17.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/file-saver": "^2.0.7",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0"
	}
}
